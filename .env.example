# Copia este archivo a .env y actualiza los valores sensibles antes de ejecutar.

# PostgreSQL configuration for the db service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=news_scrapper
POSTGRES_PORT=5432

# Optional database values for the scraper service.
# If DB_* values are missing, the app falls back to POSTGRES_*.
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=news_scrapper
DB_PORT=5432

# Optional: override the full connection URL directly.
DATABASE_URL=postgresql://postgres:your_secure_password@db:5432/news_scrapper
